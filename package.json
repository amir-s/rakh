{
  "name": "rakh-website",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://rakh.sh",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "deploy:clean": "gh-pages-clean",
    "predeploy": "npm run deploy:clean && npm run build",
    "deploy": "gh-pages -d dist -b gh-pages --nojekyll --cname rakh.sh",
    "deploy:dry-run": "npm run deploy:clean && npm run build && gh-pages -d dist -b gh-pages --nojekyll --cname rakh.sh --no-push"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "gh-pages": "^6.3.0",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.3",
    "vite": "^7.1.8"
  }
}
